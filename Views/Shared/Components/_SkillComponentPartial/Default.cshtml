@model List<Skill>

@functions {
    string GetSkillLevel(int value)
    {
        if (value < 40)
        {
            return "Beginner";
        }

        if (value < 75)
        {
            return "Intermediate";
        }

        return "Advanced";
    }
}

<div class="col-six tab-full right">
    <h3>Programlama Dilleri & Teknolojiler</h3>

    <ul class="skill-bars">
        @foreach (var item in Model)
        {
            <li>
                <div class="skill-card">
                    <strong>@item.Title</strong>
                    <span class="skill-card__level">@GetSkillLevel(item.Value)</span>
                </div>
            </li>
        }
    </ul>
</div>